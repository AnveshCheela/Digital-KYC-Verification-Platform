# ──────────────────────────────────────────
# VerifyFlow Environment Variables
# Copy to .env and fill in your values
# ──────────────────────────────────────────

# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=verifyflow
DB_PASSWORD=changeme_strong_password
DB_NAME=verifyflow

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_SECRET=your_jwt_secret_key_here_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_key_here_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=5000
NODE_ENV=development

# Resend (Email)
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=VerifyFlow <noreply@yourdomain.com>

# File Uploads
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads
